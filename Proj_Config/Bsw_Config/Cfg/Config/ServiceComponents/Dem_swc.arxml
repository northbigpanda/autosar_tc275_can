                    <COMPU-METHOD UUID="53bfb74d-4412-47e0-a70d-bb8e64d7e561">
                      <SHORT-NAME>Dem_DebouncingStateType</SHORT-NAME>
                      <CATEGORY>BITFIELD_TEXTTABLE</CATEGORY>
                      <COMPU-INTERNAL-TO-PHYS>
                        <COMPU-SCALES>
                          <COMPU-SCALE>
                            <SHORT-LABEL>DEM_TEMPORARILY_DEFECTIVE</SHORT-LABEL>
                            <SYMBOL>DEM_TEMPORARILY_DEFECTIVE</SYMBOL>
                            <DESC>
                              <L-2 L="FOR-ALL">Bit 0: Temporarily Defective (corresponds to 0 &lt; FDC &lt; 127)</L-2>
                            </DESC>
                            <MASK>1</MASK>
                            <LOWER-LIMIT INTERVAL-TYPE="CLOSED">1</LOWER-LIMIT>
                            <UPPER-LIMIT INTERVAL-TYPE="CLOSED">1</UPPER-LIMIT>
                            <COMPU-CONST>
                              <VT>DEM_TEMPORARILY_DEFECTIVE</VT>
                            </COMPU-CONST>
                          </COMPU-SCALE>
                          <COMPU-SCALE>
                            <SHORT-LABEL>DEM_FINALLY_DEFECTIVE</SHORT-LABEL>
                            <SYMBOL>DEM_FINALLY_DEFECTIVE</SYMBOL>
                            <DESC>
                              <L-2 L="FOR-ALL">Bit 1: Finally Defective (corresponds to FDC = 127)</L-2>
                            </DESC>
                            <MASK>2</MASK>
                            <LOWER-LIMIT INTERVAL-TYPE="CLOSED">2</LOWER-LIMIT>
                            <UPPER-LIMIT INTERVAL-TYPE="CLOSED">2</UPPER-LIMIT>
                            <COMPU-CONST>
                              <VT>DEM_FINALLY_DEFECTIVE</VT>
                            </COMPU-CONST>
                          </COMPU-SCALE>
                          <COMPU-SCALE>
                            <SHORT-LABEL>DEM_TEMPORARILY_HEALED</SHORT-LABEL>
                            <SYMBOL>DEM_TEMPORARILY_HEALED</SYMBOL>
                            <DESC>
                              <L-2 L="FOR-ALL">Bit 2: Temporarily healed (corresponds to -128 &lt; FDC &lt; 0)</L-2>
                            </DESC>
                            <MASK>4</MASK>
                            <LOWER-LIMIT INTERVAL-TYPE="CLOSED">4</LOWER-LIMIT>
                            <UPPER-LIMIT INTERVAL-TYPE="CLOSED">4</UPPER-LIMIT>
                            <COMPU-CONST>
                              <VT>DEM_TEMPORARILY_HEALED</VT>
                            </COMPU-CONST>
                          </COMPU-SCALE>
                          <COMPU-SCALE>
                            <SHORT-LABEL>DEM_TEST_COMPLETE</SHORT-LABEL>
                            <SYMBOL>DEM_TEST_COMPLETE</SYMBOL>
                            <DESC>
                              <L-2 L="FOR-ALL">Bit 3: Test complete (corresponds to FDC = -128 or FDC = 127)</L-2>
                            </DESC>
                            <MASK>8</MASK>
                            <LOWER-LIMIT INTERVAL-TYPE="CLOSED">8</LOWER-LIMIT>
                            <UPPER-LIMIT INTERVAL-TYPE="CLOSED">8</UPPER-LIMIT>
                            <COMPU-CONST>
                              <VT>DEM_TEST_COMPLETE</VT>
                            </COMPU-CONST>
                          </COMPU-SCALE>
                          <COMPU-SCALE>
                            <SHORT-LABEL>DEM_DTR_UPDATE</SHORT-LABEL>
                            <SYMBOL>DEM_DTR_UPDATE</SYMBOL>
                            <DESC>
                              <L-2 L="FOR-ALL">Bit 4: DTR Update (= Test complete &amp;&amp; Debouncing complete &amp;&amp; enable conditions / storage conditions fulfilled)</L-2>
                            </DESC>
                            <MASK>16</MASK>
                            <LOWER-LIMIT INTERVAL-TYPE="CLOSED">16</LOWER-LIMIT>
                            <UPPER-LIMIT INTERVAL-TYPE="CLOSED">16</UPPER-LIMIT>
                            <COMPU-CONST>
                              <VT>DEM_DTR_UPDATE</VT>
                            </COMPU-CONST>
                          </COMPU-SCALE>
                        </COMPU-SCALES>
                      </COMPU-INTERNAL-TO-PHYS>
                    </COMPU-METHOD>
