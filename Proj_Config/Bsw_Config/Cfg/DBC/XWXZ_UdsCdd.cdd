</DESC>
<QUAL>Powertrain_CAN.Baudrate</QUAL>
</UNSDEF>
<UNSDEF id='_00000230E765ECB0' oid='E549E1F32609413382F682CEE38EC55E' temploid='E70B735A87324ba88DABEB0BFD47FC4F' attrcatref='_00000230E5592D00' usage='sys' v='0' df='hex'>
