<NAME>
<TUV xml:lang='en-US'>Transport Protocol Type</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Type of used Transport Protocol (e.g. ISO15765)</TUV>
</DESC>
<QUAL>Powertrain_CAN.TransportProtocolType</QUAL>
<ETAG v='0'>
<TUV xml:lang='en-US'>ISO15765</TUV>
</ETAG>
