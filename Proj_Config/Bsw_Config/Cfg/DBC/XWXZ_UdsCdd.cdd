<ENUMDEF id='_00000230C58BD430' oid='8AD207EA9DFF4d84A6AC97E2B8058066' temploid='D3660C4FD7AB4cfdB3541E3B0041D390' attrcatref='_00000230E5592D00' usage='sys' v='0' sort='id'>
