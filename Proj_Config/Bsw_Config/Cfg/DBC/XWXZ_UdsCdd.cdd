<ETAG v='0'>
<TUV xml:lang='en-US'>not supported</TUV>
</ETAG>
<ETAG v='1'>
<TUV xml:lang='en-US'>supported</TUV>
</ETAG>
</ENUMDEF>
<ENUMDEF id='_00000230E76751A0' oid='A4DC7C3646934bf3A7D73BDF4FC85923' attrcatref='_00000230E5592D00' usage='admin' v='0' sort='id'>
<NAME>
<TUV xml:lang='en-US'>Bus Type</TUV>
</NAME>
