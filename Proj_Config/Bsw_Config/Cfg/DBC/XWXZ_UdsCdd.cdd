<ENUMDEF id='_00000230E7638860' oid='5DA19BCCBB924141895DB57112130EBF' temploid='F5B1FA24E9CC4436BFE57871BF3FD7EB' attrcatref='_00000230E5592D00' usage='sys' v='1' sort='id'>
<NAME>
<TUV xml:lang='en-US'>FillerByteHandling</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Enables use of fill bytes; if "true", fill bytes are used, otherwise DLC may be smaller than 8.</TUV>
</DESC>
<QUAL>Comfort_CAN.FillerByteHandling</QUAL>
<ETAG v='0'>
<TUV xml:lang='en-US'>false</TUV>
</ETAG>
<ETAG v='1'>
