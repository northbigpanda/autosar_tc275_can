</NAME>
<DESC>
<TUV xml:lang='en-US'>Time for next transmission of flow control</TUV>
</DESC>
<QUAL>Powertrain_CAN.TimeBr</QUAL>
</UNSDEF>
<UNSDEF id='_00000230E7660200' oid='7D4C1EFACBA841e18294C2CF9256A347' temploid='8A1F1A9BC50C4316A5A851EE33A2B092' attrcatref='_00000230E75FA9A0' usage='sys' v='100' df='dec'>
