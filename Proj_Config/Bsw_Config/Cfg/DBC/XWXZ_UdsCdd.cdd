</ETAG>
</ENUMDEF>
<UNSDEF id='_00000230E761B490' oid='E6B1436E96D2400185A4DFE725E2FF6D' temploid='EC7686F6ED7A4faaA742041EFEA81BFC' attrcatref='_00000230E5592D00' usage='sys' v='1793' df='hex'>
<NAME>
<TUV xml:lang='en-US'>Request CAN-ID</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>The request CAN identifier for physical requests. The hex value not only describes the identifier but also the priority of the message. The higher the number, the lower the priority.</TUV>
</DESC>
<QUAL>Diagnostic_CAN.ReqCanId</QUAL>
</UNSDEF>
<UNSDEF id='_00000230E761C410' oid='231ED964A4214e088C9686BED51F5199' temploid='418AC10E68CC48c38096757D606611D6' attrcatref='_00000230E5592D00' usage='sys' v='1873' df='hex'>
<NAME>
<TUV xml:lang='en-US'>Response CAN-ID</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>The response CAN identifier for physical responses.The response for functional requests is sent via the physical path.</TUV>
</DESC>
<QUAL>Diagnostic_CAN.ResCanId</QUAL>
</UNSDEF>
<ENUMDEF id='_00000230E74D1CE0' oid='EF8DA156AF5345b38BA911D3613981C5' temploid='06E3BDAEBEDD4419AB53F9A17E19DF17' attrcatref='_00000230E5592D00' usage='sys' v='0' sort='id'>
<NAME>
