</NAME>
<QUAL>Occurrence_Counter</QUAL>
<STRUCTURE>
<DATAOBJ oid='{65F19380-2225-46ed-83CE-427DA9DB223D}' spec='no' dtref='_00000230E772D170'>
<NAME>
<TUV xml:lang='en-US'>Driving Cycles Since Test Failed</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Counts the number of driving cycles in which "test failed" has been reported</TUV>
</DESC>
<QUAL>Driving_Cycles_Since_Test_Failed</QUAL>
</DATAOBJ>
</STRUCTURE>
</EXTENDEDDATARECORD>
<EXTENDEDDATARECORD oid='{A5F19310-2225-46ed-83CE-427DA9DB223D-DAC}' rn='11' mayBeMod='1' mayBeDel='0' mayBeModData='1' supportEdrForDtc='1'>
