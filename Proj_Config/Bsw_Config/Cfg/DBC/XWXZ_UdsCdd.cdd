</NAME>
<DESC>
<TUV xml:lang='en-US'>Time until reception of next flow control</TUV>
</DESC>
<QUAL>Powertrain_CAN.TimeoutBs</QUAL>
</UNSDEF>
<UNSDEF id='_00000230E76609C0' oid='802B22E6CBD94d34A175387C8EACE686' temploid='307C69EB44164a1d8EBFA131BC721DCC' attrcatref='_00000230E75FA9A0' usage='sys' v='100' df='dec'>
<NAME>
