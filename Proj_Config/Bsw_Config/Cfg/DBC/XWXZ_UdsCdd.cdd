</NAME>
<DESC>
<TUV xml:lang='en-US'>Time until next transmission of consecutive frame</TUV>
</DESC>
<QUAL>CAN_FD.TimeCs</QUAL>
</UNSDEF>
<UNSDEF id='_00000230E7677450' oid='412AF4862D8A4cc4822F217920C3AD2D' attrcatref='_00000230E75FA9A0' usage='admin' v='1000' df='dec'>
<NAME>
