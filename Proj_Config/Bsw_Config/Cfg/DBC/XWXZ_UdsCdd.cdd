<TUV xml:lang='en-US'>Fill byte used for filling CAN frames to eight byte length.</TUV>
</DESC>
<QUAL>Powertrain_CAN.CANFrameFillerByte</QUAL>
</UNSDEF>
<ENUMDEF id='_00000230E7674FC0' oid='AFD490D992274ebaA239A74A67E4DEE0' temploid='5FEBAB233A12451fA18FBA94F2056927' attrcatref='_00000230E5592D00' usage='sys' v='1' sort='id'>
<NAME>
<TUV xml:lang='en-US'>FillerByteHandling</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Enables use of fill bytes; if "true", fill bytes are used, otherwise DLC may be smaller than 8.</TUV>
</DESC>
<QUAL>Powertrain_CAN.FillerByteHandling</QUAL>
<ETAG v='0'>
<TUV xml:lang='en-US'>false</TUV>
</ETAG>
<ETAG v='1'>
<TUV xml:lang='en-US'>true</TUV>
</ETAG>
</ENUMDEF>
