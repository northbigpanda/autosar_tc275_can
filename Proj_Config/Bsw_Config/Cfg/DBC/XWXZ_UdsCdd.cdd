</DESC>
<QUAL>Powertrain_CAN.AddrScheme</QUAL>
<ETAG v='0'>
<TUV xml:lang='en-US'>Normal</TUV>
</ETAG>
</ENUMDEF>
<ENUMDEF id='_00000230E7638FE0' oid='ED4CB10752A14929B3336714A6BE9423' temploid='BAF36F2BDDC94a8b915FD1793E6D17B2' attrcatref='_00000230E5592D00' usage='sys' v='0' sort='id'>
<NAME>
<TUV xml:lang='en-US'>CAN-ID Type</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>CAN-ID Type used for physical requests and responses</TUV>
</DESC>
<QUAL>Powertrain_CAN.CanIdType</QUAL>
<ETAG v='0'>
<TUV xml:lang='en-US'>11-Bit</TUV>
</ETAG>
<ETAG v='1'>
<TUV xml:lang='en-US'>29-Bit</TUV>
</ETAG>
</ENUMDEF>
<UNSDEF id='_00000230E764C7B0' oid='7F189627A2DF4fe2B753F36453D0B678' temploid='61008F92CB424728B5AA59150711BC3A' attrcatref='_00000230E5592D00' usage='sys' v='1792' df='hex'>
<NAME>
<TUV xml:lang='en-US'>Request CAN-ID</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>The request CAN identifier for physical requests. The hex value not only describes the identifier but also the priority of the message. The higher the number, the lower the priority.</TUV>
</DESC>
<QUAL>Powertrain_CAN.ReqCanId</QUAL>
</UNSDEF>
<UNSDEF id='_00000230E764BC10' oid='CEABBAADCB024cb9B85C9F72F28A4755' temploid='19E72B56FE1E477fAE80B7B343C77768' attrcatref='_00000230E5592D00' usage='sys' v='1536' df='hex'>
<NAME>
<TUV xml:lang='en-US'>Response CAN-ID</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>The response CAN identifier for physical responses.The response for functional requests is sent via the physical path.</TUV>
</DESC>
<QUAL>Powertrain_CAN.ResCanId</QUAL>
</UNSDEF>
<ENUMDEF id='_00000230E7637960' oid='477AE48451984eef9CA239C153DFEA9F' temploid='59CE05710CB74f1099DEB56896F5C38A' attrcatref='_00000230E5592D00' usage='sys' v='0' sort='id'>
<NAME>
<TUV xml:lang='en-US'>Functional Addressing Scheme</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Addressing Scheme used for functional requests.</TUV>
</DESC>
<QUAL>Powertrain_CAN.AddrSchemeFunc</QUAL>
<ETAG v='0'>
<TUV xml:lang='en-US'>Normal</TUV>
</ETAG>
</ENUMDEF>
<ENUMDEF id='_00000230E7637F00' oid='0C24E66F5F7E43b9990F27405DF5713A' temploid='ADF01A2089364db78FF0ECA80D2FFEA5' attrcatref='_00000230E5592D00' usage='sys' v='0' sort='id'>
<NAME>
<TUV xml:lang='en-US'>Functional CAN-ID Type</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>CAN-ID Type used for functional request</TUV>
</DESC>
<QUAL>Powertrain_CAN.CanIdTypeFunc</QUAL>
<ETAG v='0'>
<TUV xml:lang='en-US'>11-Bit</TUV>
</ETAG>
<ETAG v='1'>
<TUV xml:lang='en-US'>29-Bit</TUV>
</ETAG>
