<STRUCTURE>
<DATAOBJ oid='{65F19380-2225-46ed-83CE-427DA9DB223D-OBD}' spec='no' dtref='_00000230E772D170'>
<NAME>
<TUV xml:lang='en-US'>Driving Cycles Until "Check Engine" Lamp Off</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Counts the number of driving cycles until "Check Engine" lamp will be switched off if the driving cycle can be performed in a fault free mode</TUV>
</DESC>
<QUAL>Driving_Cycles_Until_Check_Engine_Lamp_Off</QUAL>
</DATAOBJ>
<DATAOBJ oid='{65F19380-2225-46ed-83CE-427DA9DB223D-OBD2}' spec='no' dtref='_00000230E772D170'>
<NAME>
<TUV xml:lang='en-US'>Malfunction Indicator Counter</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Counts the number of engine operating hours during which the OBD system operated with a malfunction active (DTC B1)</TUV>
</DESC>
<QUAL>Malfunction_Indicator_Counter</QUAL>
</DATAOBJ>
</STRUCTURE>
</EXTENDEDDATARECORD>
<EXTENDEDDATARECORD oid='{A5F19310-2225-46ed-83CE-427DA9DB223D}' rn='10' mayBeMod='1' mayBeDel='0' mayBeModData='1' supportEdrForDtc='1'>
<NAME>
